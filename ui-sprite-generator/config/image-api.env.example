# Copy this file to the run directory as `.env` and edit it there.
# Do not commit the copied `.env` file.

# OpenAI-compatible image endpoint base URL. Include the full endpoint path.
# Examples:
# IMAGE_API_BASE_URL=https://api.openai.com/v1/images/generations
# IMAGE_API_BASE_URL=https://example.local/v1/images/edits
IMAGE_API_BASE_URL=

# Use a temporary, low-scope, revocable key. Keep it out of prompts and logs.
IMAGE_API_KEY=

# Provider-specific image model name.
IMAGE_API_MODEL=

# Optional defaults.
IMAGE_API_SIZE=1536x1024
IMAGE_API_QUALITY=high
IMAGE_API_RESPONSE_FORMAT=b64_json
IMAGE_API_TIMEOUT=180
